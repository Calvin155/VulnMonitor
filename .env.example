# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret

# ── Database (same Postgres the pentester container uses) ─────────────────────
PGHOST=db
PGPORT=5432
PGDATABASE=pentester
PGUSER=pentester
PGPASSWORD=your-db-password

# ── Pentester container ───────────────────────────────────────────────────────
# Use the Docker service name from the pentester compose file
PENTESTER_URL=http://api:8000

# ── Docker network ────────────────────────────────────────────────────────────
# Find it with: docker network ls | grep -i pent
PENTESTER_NETWORK=ai_pentester_default

# ── TLS ───────────────────────────────────────────────────────────────────────
PORT=443
# Copy your certs into ./certs/ as cert.pem and key.pem before starting
